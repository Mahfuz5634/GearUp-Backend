    {
      "name": "💳 Payments (Stripe)",
      "description": "Stripe payment processing via Checkout Sessions. Order must be CONFIRMED before payment.\n\nFlow: Create Session → Open URL → Pay on Stripe → Webhook auto-confirms OR use /confirm endpoint.",
      "item": [
        {
          "name": "Create Checkout Session",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('transactionId', json.data.transactionId);",
                  "    pm.collectionVariables.set('paymentId', json.data.paymentId);",
                  "    console.log('Checkout URL:', json.data.checkoutUrl);",
                  "    console.log('Transaction ID:', json.data.transactionId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rentalOrderId\": \"{{rentalOrderId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/payments/create",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payments", "create"]
            }
          }
        },
        {
          "name": "Confirm Payment (Manual)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transactionId\": \"{{transactionId}}\"\n}"
            },
