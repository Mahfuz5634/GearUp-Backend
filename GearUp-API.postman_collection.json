    {
      "name": "Rentals",
      "description": "Rental order management",
      "item": [
        {
          "name": "Create Rental Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('rentalOrderId', json.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gearId\": \"{{gearId}}\",\n  \"startDate\": \"2026-07-20\",\n  \"endDate\": \"2026-07-25\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/rentals",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rentals"]
            },
            "description": "Customer places a rental order → status: PLACED"
          }
        },
        {
          "name": "Get My Rentals (Customer)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/rentals/customer",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rentals", "customer"]
            },
            "description": "Customer views their rental orders"
          }
        },
        {
          "name": "Get Provider Orders",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{providerToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/rentals/provider",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rentals", "provider"]
            },
            "description": "Provider views incoming orders for their gear"
          }
        },
        {
          "name": "Confirm Order (Provider)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{providerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CONFIRMED\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/rentals/{{rentalOrderId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rentals", "{{rentalOrderId}}", "status"]
            },
            "description": "Provider confirms the rental order → status: CONFIRMED"
          }
        },
        {
          "name": "Mark Picked Up (Provider)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{providerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"PICKED_UP\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/rentals/{{rentalOrderId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rentals", "{{rentalOrderId}}", "status"]
            },
            "description": "Provider marks gear as picked up → status: PICKED_UP"
          }
        },
        {
          "name": "Mark Returned (Provider)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{providerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"RETURNED\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/rentals/{{rentalOrderId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rentals", "{{rentalOrderId}}", "status"]
            },
            "description": "Provider marks gear as returned → status: RETURNED (customer can now review)"
          }
        },
        {
          "name": "Cancel Order (Provider)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{providerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CANCELLED\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/rentals/{{rentalOrderId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rentals", "{{rentalOrderId}}", "status"]
            },
            "description": "Provider cancels the order → status: CANCELLED"
          }
        }
      ]
    },
